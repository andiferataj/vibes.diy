{
  "name": "@vibes-diy/pkg",
  "version": "0.0.0",
  "type": "module",
  "main": "./index.js",
  "scripts": {
    "tsc": "core-cli tsc",
    "typecheck": "core-cli tsc --noEmit",
    "build": "core-cli tsc && react-router build",
    "dev": "react-router dev",
    "pack": "echo core-cli build --doPack",
    "publish": "echo core-cli build",
    "prepreview": "CLOUDFLARE_ENV=local react-router build",
    "preview": "concurrently --kill-others \"wrangler dev --env local --port 8889\" \"node scripts/https-proxy.mjs\"",
    "drizzle:libsql": "drizzle-kit push --config ./drizzle.libsql.config.ts",
    "drizzle:d1-local": "drizzle-kit push --config ./drizzle.d1-local-backend.config.ts",
    "drizzle:d1-remote": "drizzle-kit push --config ./drizzle.d1-remote.config.ts",
    "drizzle:neon": "drizzle-kit push --config ./drizzle.neon.config.ts",
    "build:dev": "CLOUDFLARE_ENV=dev react-router build",
    "build:prod": "CLOUDFLARE_ENV=prod react-router build",
    "deploy:dev": "CLOUDFLARE_ENV=dev react-router build && wrangler deploy --env dev",
    "deploy:prod": "CLOUDFLARE_ENV=prod react-router build && wrangler deploy --env prod",
    "deploy:cli": "CLOUDFLARE_ENV=cli react-router build && wrangler deploy --env cli",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@adviser/cement": "^0.5.34",
    "@clerk/react": "^6.2.1",
    "@cloudflare/puppeteer": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260418.1",
    "@fireproof/core": "0.24.19",
    "@fireproof/core-protocols-dashboard": "0.24.19",
    "@fireproof/core-runtime": "0.24.19",
    "@fireproof/core-types-protocols-dashboard": "0.24.19",
    "@fireproof/use-fireproof": "0.24.19",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "^7.13.2",
    "@shikijs/monaco": "^4.0.2",
    "@sindresorhus/fnv1a": "^3.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@vibes.diy/api-impl": "workspace:*",
    "@vibes.diy/api-pkg": "workspace:*",
    "@vibes.diy/api-sql": "workspace:*",
    "@vibes.diy/api-svc": "workspace:*",
    "@vibes.diy/api-types": "workspace:*",
    "@vibes.diy/base": "workspace:*",
    "@vibes.diy/call-ai-v2": "workspace:*",
    "@vibes.diy/prompts": "workspace:*",
    "@vibes.diy/vibe-srv-sandbox": "workspace:*",
    "@vibes.diy/vibe-types": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "isbot": "^5.1.36",
    "mime": "^4.1.0",
    "monaco-editor": "^0.55.1",
    "multiformats": "^13.4.2",
    "posthog-js": "^1.365.5",
    "react": "^19.2.5",
    "react-cookie-consent": "^10.0.1",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.2",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "use-fireproof": "0.24.16",
    "use-vibes": "workspace:*",
    "wrangler": "^4.81.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.1",
    "@fireproof/core-cli": "0.24.19",
    "@pnpm/lockfile-file": "^9.1.3",
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/babel__standalone": "^7.1.9",
    "@types/react": "~19.2.13",
    "@types/react-dom": "~19.2.2",
    "@vitest/browser-playwright": "~4.1.4",
    "arktype": "^2.2.0",
    "cmd-ts": "^0.15.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.8",
    "find-up": "^8.0.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "toml": "^4.1.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "yaml": "^2.8.3",
    "zx": "^8.8.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VibesDIY/vibes.diy.git"
  }
}
